@page
@{
    Layout = null;
    ViewData["Title"] = "Gallery";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yeka Cleaning Services</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-page="/Index"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Index"><i class="bi bi-house-door"></i> Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Gallery"><i class="bi bi-images"></i> Gallery</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Services"><i class="bi bi-briefcase"></i> Services</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/About"><i class="bi bi-people"></i> About Us</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Contact"><i class="bi bi-envelope"></i> Contact Us</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Blog"><i class="bi bi-journal-text"></i> Blog</a></li>
                    <li class="nav-item ms-lg-3"><a class="login-btn" asp-area="" asp-page="/Login">Login</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container py-5" style="margin-top: 80px;">
    <h1 class="text-center mb-5">Our Work Gallery</h1>
    <div class="row g-4">
        @for (int i = 1; i <= 6; i++)
        {
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="https://picsum.photos/400/300?random=@i" class="card-img-top" alt="Cleaning Work @(i)">
                    <div class="card-body">
                        <h5 class="card-title">Project @i</h5>
                        <p class="card-text">Professional cleaning service completed.</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<footer>
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4"><h5><i class="bi bi-droplet-fill"></i> Yeka Cleaning</h5><p>Your trusted partner.</p></div>
            <div class="col-md-4 mb-4"><h5>Quick Links</h5><ul class="list-unstyled"><li><a asp-page="/Services">Services</a></li><li><a asp-page="/About">About Us</a></li><li><a asp-page="/Contact">Contact</a></li></ul></div>
            <div class="col-md-4 mb-4"><h5>Contact</h5><p>(555) 123-4567</p></div>
        </div>
        <div class="text-center border-top pt-3"><p class="mb-0">&copy; 2026 Yeka Cleaning.</p></div>
    </div>
</footer>

<button class="chatbot-btn" onclick="alert('Chat support coming soon!')"><i class="bi bi-chat-dots-fill"></i></button>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>