@page
@model CleaningManagmentSystem.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password - Yeka Cleaning";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            overflow: hidden;
            max-width: 450px;
            width: 100%;
        }
        .login-header {
            background: darkcyan;
            color: white;
            padding: 30px;
            text-align: center;
        }
        .login-header h1 {
            margin: 0;
            font-size: 24px;
        }
        .login-body {
            padding: 40px;
        }
        .form-control {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 12px 15px;
        }
        .form-control:focus {
            border-color: darkcyan;
            box-shadow: 0 0 0 3px rgba(0, 128, 128, 0.1);
        }
        .btn-login {
            background: darkcyan;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: 600;
            width: 100%;
            transition: background 0.3s;
        }
        .btn-login:hover {
            background: #006666;
        }
        .back-link {
            color: darkcyan;
            text-decoration: none;
        }
        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <i class="bi bi-droplet-fill" style="font-size: 40px;"></i>
            <h1 class="mt-2">Yeka Cleaning</h1>
            <p class="mb-0 opacity-75">Forgot Password</p>
        </div>
        <div class="login-body">
            @if (Model.IsSuccess)
            {
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@Model.Message
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@Model.Message
                    </div>
                }

                <p class="text-muted mb-4">Enter your email address and we'll send you a link to reset your password.</p>

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input type="email" class="form-control" asp-for="Email" placeholder="Enter your email" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-login mb-3">
                        <i class="bi bi-send me-2"></i>Send Reset Link
                    </button>
                </form>
            }

            <div class="text-center mt-3">
                <a href="/Login" class="back-link">
                    <i class="bi bi-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </div>
    </div>
</body>
</html>