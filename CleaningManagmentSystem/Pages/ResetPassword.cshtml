@page
@model CleaningManagmentSystem.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password - Yeka Cleaning";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            overflow: hidden;
            max-width: 450px;
            width: 100%;
        }
        .login-header {
            background: darkcyan;
            color: white;
            padding: 30px;
            text-align: center;
        }
        .login-header h1 { margin: 0; font-size: 24px; }
        .login-body { padding: 40px; }
        .form-control {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 12px 15px;
        }
        .form-control:focus {
            border-color: darkcyan;
            box-shadow: 0 0 0 3px rgba(0, 128,128,0.1);
        }
        .btn-login {
            background: darkcyan;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: 600;
            width: 100%;
            transition: background 0.3s;
        }
        .btn-login:hover { background: #006666; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <i class="bi bi-droplet-fill" style="font-size: 40px;"></i>
            <h1 class="mt-2">Yeka Cleaning</h1>
            <p class="mb-0 opacity-75">Reset Password</p>
        </div>
        <div class="login-body">
            @if (Model.IsSuccess)
            {
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@Model.Message
                </div>
                <div class="text-center mt-3">
                    <a href="/Login" class="btn btn-login">Go to Login</a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@Model.Message
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Token" />
                    
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" class="form-control" asp-for="NewPassword" placeholder="Enter new password" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" asp-for="ConfirmPassword" placeholder="Confirm new password" required />
                    </div>
                    <button type="submit" class="btn btn-login mb-3">
                        <i class="bi bi-check-lg me-2"></i>Reset Password
                    </button>
                </form>
            }
        </div>
    </div>
</body>
</html>