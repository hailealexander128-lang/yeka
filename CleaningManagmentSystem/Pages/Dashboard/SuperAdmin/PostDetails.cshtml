@page "{id:int}"
@model CleaningManagmentSystem.Pages.Dashboard.SuperAdmin.PostDetailsModel
@{
    var userName = HttpContext.Session.GetString("UserName");
    if (userName == null) { Response.Redirect("/Login"); return; }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post Details - @Model.Post.Title - Super Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        .attribute-card {
            border-radius: 12px;
            background: #ffffff;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            border: none;
            margin-bottom: 24px;
            overflow: hidden;
        }
        .attribute-card .card-header {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: #ffffff;
            border-bottom: none;
            padding: 16px 20px;
        }
        .attribute-card .card-body {
            padding: 24px;
        }
        .btn-action-panel {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .training-banner {
            background: linear-gradient(135deg, #eff6ff, #dbeafe);
            border-left: 5px solid #3b82f6;
            border-radius: 8px;
            padding: 20px;
        }
        .detail-value {
            font-weight: 600;
            color: #1e293b;
        }
        .detail-label {
            font-size: 0.85rem;
            color: #64748b;
            text-uppercase: uppercase;
            letter-spacing: 0.5px;
        }
        .badge-priority-high {
            background-color: #ef4444;
            color: #ffffff;
        }
        .badge-priority-medium {
            background-color: #f59e0b;
            color: #1e293b;
        }
        .badge-priority-normal {
            background-color: #3b82f6;
            color: #ffffff;
        }
    </style>
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>
    
    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
                @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
                <nav aria-label="breadcrumb" class="pt-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Dashboard/SuperAdmin">Home</a></li>
                        <li class="breadcrumb-item"><a href="/Dashboard/SuperAdmin/Post">Post Management</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Post Details</li>
                    </ol>
                </nav>

                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
                    <h1 class="h2">
                        @if (Model.Post.IsPinned)
                        {
                            <i class="bi bi-pin-angle-fill text-danger me-2" title="Pinned Post"></i>
                        }
                        @Model.Post.Title
                    </h1>
                    <div>
                        <a href="/Dashboard/SuperAdmin/Post" class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-arrow-left me-1"></i>Back to Posts</a>
                        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#editContentModal"><i class="bi bi-pencil me-1"></i>Edit Title & Content</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="row">
                    <!-- Left Column: Content & Training details -->
                    <div class="col-lg-8">
                        <!-- Post Body Card -->
                        <div class="card attribute-card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="bi bi-file-text me-2"></i>Post Content</h5>
                                <span class="badge bg-light text-dark text-uppercase">@Model.Post.Category</span>
                            </div>
                            <div class="card-body">
                                <div class="mb-4">
                                    <div class="row g-3">
                                        <div class="col-6 col-md-3">
                                            <div class="detail-label">Status</div>
                                            <div>
                                                @{
                                                    var statusBadge = Model.Post.Status switch
                                                    {
                                                        "Published" => "bg-success",
                                                        "Draft" => "bg-secondary",
                                                        "Deleted" => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @statusBadge">@Model.Post.Status</span>
                                            </div>
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <div class="detail-label">Priority</div>
                                            <div>
                                                @{
                                                    var priorityBadge = Model.Post.Priority switch
                                                    {
                                                        "High" => "badge-priority-high",
                                                        "Medium" => "badge-priority-medium",
                                                        _ => "badge-priority-normal"
                                                    };
                                                }
                                                <span class="badge @priorityBadge">@Model.Post.Priority</span>
                                            </div>
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <div class="detail-label">Target Audience</div>
                                            <div>
                                                @{
                                                    var targetLabel = Model.Post.TargetRole switch
                                                    {
                                                        "All" => "All Users (Public)",
                                                        "staff" => "Staff Members Only",
                                                        "cleaner" => "Cleaners Only",
                                                        "wereda_mahberat" => "Wereda Mahberat",
                                                        "dispatch_officer" => "Dispatch Officers",
                                                        "driver" => "Drivers Only",
                                                        "manager" => "Managers Only",
                                                        _ => Model.Post.TargetRole
                                                    };
                                                }
                                                <span class="badge bg-dark text-white">@targetLabel</span>
                                            </div>
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <div class="detail-label">Pinned Status</div>
                                            <div>
                                                @if (Model.Post.IsPinned)
                                                {
                                                    <span class="badge bg-danger"><i class="bi bi-pin-angle-fill me-1"></i>Pinned</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-muted border">Unpinned</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div style="font-size: 1.1rem; line-height: 1.7; color: #334155; white-space: pre-wrap;" class="py-2">@Model.Post.Content</div>
                            </div>
                        </div>

                        <!-- Linked Training Detail Card -->
                        @if (Model.LinkedTraining != null)
                        {
                            <div class="card attribute-card">
                                <div class="card-header bg-primary">
                                    <h5 class="mb-0 text-white"><i class="bi bi-mortarboard-fill me-2"></i>Linked Training Program Details</h5>
                                </div>
                                <div class="card-body">
                                    <div class="training-banner mb-4">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <h4 class="text-primary mb-1">@Model.LinkedTraining.Title</h4>
                                                <p class="text-muted mb-0">Trainer: <strong>@Model.LinkedTraining.Trainer</strong></p>
                                            </div>
                                            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                                <span class="badge bg-primary px-3 py-2" style="font-size: 0.9rem;">@Model.LinkedTraining.Status</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row g-4 mb-4">
                                        <div class="col-sm-6 col-md-4">
                                            <div class="detail-label">Location</div>
                                            <div class="detail-value"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@Model.LinkedTraining.Location</div>
                                        </div>
                                        <div class="col-sm-6 col-md-4">
                                            <div class="detail-label">Start Date</div>
                                            <div class="detail-value"><i class="bi bi-calendar-event me-1 text-primary"></i>@Model.LinkedTraining.StartDate.ToString("yyyy-MM-dd")</div>
                                        </div>
                                        <div class="col-sm-6 col-md-4">
                                            <div class="detail-label">End Date</div>
                                            <div class="detail-value"><i class="bi bi-calendar-check me-1 text-success"></i>@Model.LinkedTraining.EndDate.ToString("yyyy-MM-dd")</div>
                                        </div>
                                        <div class="col-sm-6 col-md-4">
                                            <div class="detail-label">Materials Provided</div>
                                            <div class="detail-value">
                                                @if (!string.IsNullOrEmpty(Model.LinkedTraining.Materials))
                                                {
                                                    @foreach (var mat in Model.LinkedTraining.Materials.Split(','))
                                                    {
                                                        <span class="badge bg-secondary me-1">@mat.Trim()</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">None</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="col-sm-6 col-md-4">
                                            <div class="detail-label">Estimated Participants</div>
                                            <div class="detail-value"><i class="bi bi-people-fill text-dark me-1"></i>@Model.LinkedTraining.Participants</div>
                                        </div>
                                    </div>

                                    <div class="detail-label">Training Description</div>
                                    <p class="mt-1 text-muted" style="line-height: 1.6;">@Model.LinkedTraining.Description</p>
                                </div>
                            </div>
                        }
                        else if (Model.Post.Category == "Training" || Model.Post.TrainingId.HasValue)
                        {
                            <div class="card attribute-card border-danger">
                                <div class="card-body text-center py-4">
                                    <i class="bi bi-exclamation-octagon text-danger display-5"></i>
                                    <h5 class="mt-2 text-danger">Linked Training Record Missing</h5>
                                    <p class="text-muted mb-0">This post is categorized under Training or has a training reference ID, but no corresponding training record was found in the database. Please select a valid training in the "Update Attributes" panel on the right.</p>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Right Column: Quick actions, metadata, attributes update -->
                    <div class="col-lg-4">
                        <!-- Quick Status Action Card -->
                        <div class="card attribute-card">
                            <div class="card-header bg-dark">
                                <h5 class="mb-0"><i class="bi bi-lightning-fill text-warning me-2"></i>Status & Publish Action</h5>
                            </div>
                            <div class="card-body">
                                <div class="btn-action-panel">
                                    @if (Model.Post.Status == "Draft")
                                    {
                                        <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@Model.Post.Id">
                                            <input type="hidden" name="status" value="Published" />
                                            <button type="submit" class="btn btn-success w-100 py-2"><i class="bi bi-send-fill me-2"></i>Publish Live Now</button>
                                        </form>
                                    }
                                    else if (Model.Post.Status == "Published")
                                    {
                                        <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@Model.Post.Id">
                                            <input type="hidden" name="status" value="Draft" />
                                            <button type="submit" class="btn btn-secondary w-100 py-2"><i class="bi bi-archive-fill me-2"></i>Revert to Draft</button>
                                        </form>
                                    }

                                    @if (Model.Post.Status != "Deleted")
                                    {
                                        <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@Model.Post.Id" onsubmit="return confirm('Are you sure you want to soft delete this post?');">
                                            <input type="hidden" name="status" value="Deleted" />
                                            <button type="submit" class="btn btn-outline-danger w-100 py-2"><i class="bi bi-trash3 me-2"></i>Move to Trash (Delete)</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="ChangeStatus" asp-route-id="@Model.Post.Id">
                                            <input type="hidden" name="status" value="Draft" />
                                            <button type="submit" class="btn btn-warning w-100 py-2"><i class="bi bi-arrow-counterclockwise me-2"></i>Restore as Draft</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Update Attributes Card -->
                        <div class="card attribute-card">
                            <div class="card-header bg-secondary">
                                <h5 class="mb-0 text-white"><i class="bi bi-sliders me-2"></i>Modify Attributes</h5>
                            </div>
                            <div class="card-body">
                                <form method="post" asp-page-handler="UpdateAttributes" asp-route-id="@Model.Post.Id">
                                    <div class="mb-3">
                                        <label class="form-label text-muted small">Category</label>
                                        <select class="form-select" name="category" required>
                                            <option value="Notice" selected="@(Model.Post.Category == "Notice")">Notice</option>
                                            <option value="Blog" selected="@(Model.Post.Category == "Blog")">Blog</option>
                                            <option value="Training" selected="@(Model.Post.Category == "Training")">Training</option>
                                            <option value="Announcement" selected="@(Model.Post.Category == "Announcement")">Announcement</option>
                                            <option value="Policy" selected="@(Model.Post.Category == "Policy")">Policy</option>
                                            <option value="Event" selected="@(Model.Post.Category == "Event")">Event</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small">Target Audience (Role Access)</label>
                                        <select class="form-select" name="targetRole">
                                            <option value="All" selected="@(Model.Post.TargetRole == "All")">All Users (Public)</option>
                                            <option value="staff" selected="@(Model.Post.TargetRole == "staff")">Staff Members Only</option>
                                            <option value="cleaner" selected="@(Model.Post.TargetRole == "cleaner")">Cleaners Only</option>
                                            <option value="wereda_mahberat" selected="@(Model.Post.TargetRole == "wereda_mahberat")">Wereda Mahberat Only</option>
                                            <option value="dispatch_officer" selected="@(Model.Post.TargetRole == "dispatch_officer")">Dispatch Officers Only</option>
                                            <option value="driver" selected="@(Model.Post.TargetRole == "driver")">Drivers Only</option>
                                            <option value="manager" selected="@(Model.Post.TargetRole == "manager")">Managers Only</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small">Priority Level</label>
                                        <select class="form-select" name="priority">
                                            <option value="Normal" selected="@(Model.Post.Priority == "Normal")">Normal</option>
                                            <option value="Medium" selected="@(Model.Post.Priority == "Medium")">Medium</option>
                                            <option value="High" selected="@(Model.Post.Priority == "High")">High / Critical</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small">Link to Training Record</label>
                                        <select class="form-select" name="trainingId">
                                            <option value="">None / Not a Training Post</option>
                                            @foreach (var tr in Model.TrainingList)
                                            {
                                                <option value="@tr.Id" selected="@(Model.Post.TrainingId == tr.Id)">@tr.Title</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-check mb-4">
                                        <input class="form-check-input" type="checkbox" name="isPinned" id="isPinnedCheck" value="true" checked="@(Model.Post.IsPinned ? "checked" : null)">
                                        <label class="form-check-label" for="isPinnedCheck">
                                            <strong>Pin to top</strong>
                                        </label>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 py-2"><i class="bi bi-check-lg me-2"></i>Save Attributes</button>
                                </form>
                            </div>
                        </div>

                        <!-- Metadata Info Card -->
                        <div class="card attribute-card">
                            <div class="card-header bg-light text-dark border-bottom">
                                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Metadata</h5>
                            </div>
                            <div class="card-body py-3">
                                <div class="mb-2">
                                    <span class="detail-label">Created At</span>
                                    <div class="text-dark small">@Model.Post.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss")</div>
                                </div>
                                <div class="mb-2">
                                    <span class="detail-label">Last Updated</span>
                                    <div class="text-dark small">@(Model.Post.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")</div>
                                </div>
                                <div>
                                    <span class="detail-label">Published At</span>
                                    <div class="text-dark small">@(Model.Post.PublishedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Not published yet")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Edit Title & Content Modal -->
    <div class="modal fade" id="editContentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" asp-page-handler="UpdateContent" asp-route-id="@Model.Post.Id">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Post Title & Content</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Post Title</label>
                            <input type="text" class="form-control" name="title" value="@Model.Post.Title" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Post Content Body</label>
                            <textarea class="form-control" name="content" rows="12" required>@Model.Post.Content</textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
    </script>
</body>
</html>
