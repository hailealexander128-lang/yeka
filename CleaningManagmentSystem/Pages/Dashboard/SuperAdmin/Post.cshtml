@page
@model CleaningManagmentSystem.Pages.Dashboard.SuperAdmin.PostModel
@{
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole")?.ToLower();
    if (userName == null) { Response.Redirect("/Login"); return; }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post Management - Super Admin - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>
    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>
    <nav id="sidebarMenu" class="sidebar d-lg-none">
        @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
    </nav>
    <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
        @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
    </nav>

    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2">Post Management</h1>
            <span class="badge bg-danger">Super Admin</span>
        </div>

        <div class="mb-3">
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPostModal"><i class="bi bi-plus-circle me-1"></i>Create Post</button>
        </div>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Audience</th>
                    <th>Priority</th>
                    <th>Training Ref</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Posts != null && Model.Posts.Any())
                {
                    foreach (var post in Model.Posts)
                    {
                        <tr class="@(post.IsPinned ? "table-warning bg-opacity-10" : "")">
                            <td>@post.Id</td>
                            <td>
                                @if (post.IsPinned)
                                {
                                    <i class="bi bi-pin-angle-fill text-danger me-1" title="Pinned Notice"></i>
                                }
                                <span class="fw-bold">@post.Title</span>
                            </td>
                            <td>
                                @{
                                    var categoryBadge = post.Category switch
                                    {
                                        "Notice" => "bg-primary text-white",
                                        "Blog" => "bg-success text-white",
                                        "Training" => "bg-info text-dark",
                                        "Announcement" => "bg-warning text-dark",
                                        "Policy" => "bg-dark text-white",
                                        _ => "bg-secondary text-white"
                                    };
                                }
                                <span class="badge @categoryBadge">@post.Category</span>
                            </td>
                            <td>
                                @{
                                    var audienceLabel = post.TargetRole switch
                                    {
                                        "All" => "All (Public)",
                                        "staff" => "Staff Only",
                                        "cleaner" => "Cleaners Only",
                                        "wereda_mahberat" => "Wereda Mahberat",
                                        "dispatch_officer" => "Dispatch Officers",
                                        "driver" => "Drivers Only",
                                        "manager" => "Managers Only",
                                        _ => post.TargetRole
                                    };
                                    var audienceBadge = post.TargetRole == "All" ? "bg-light text-dark border" : "bg-dark text-white";
                                }
                                <span class="badge @audienceBadge" style="font-size: 0.8rem;">@audienceLabel</span>
                            </td>
                            <td>
                                @{
                                    var priorityBadge = post.Priority switch
                                    {
                                        "High" => "bg-danger text-white",
                                        "Medium" => "bg-warning text-dark",
                                        _ => "bg-info text-dark"
                                    };
                                }
                                <span class="badge @priorityBadge">@post.Priority</span>
                            </td>
                            <td>
                                @if (post.TrainingId.HasValue)
                                {
                                    <span class="badge bg-primary text-white"><i class="bi bi-mortarboard me-1"></i>ID: @post.TrainingId</span>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td>@post.CreatedAt?.ToString("yyyy-MM-dd")</td>
                            <td>
                                @{
                                    var badgeClass = post.Status switch
                                    {
                                        "Published" => "bg-success",
                                        "Draft" => "bg-secondary",
                                        "Deleted" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@post.Status</span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-primary btn-edit-post" 
                                            data-id="@post.Id"
                                            data-title="@post.Title"
                                            data-category="@post.Category"
                                            data-content="@post.Content"
                                            data-status="@post.Status"
                                            data-trainingid="@(post.TrainingId?.ToString() ?? "")"
                                            data-ispinned="@post.IsPinned.ToString().ToLower()"
                                            data-priority="@post.Priority"
                                            data-targetrole="@post.TargetRole"
                                            title="Edit Post Attributes">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </button>
                                    
                                    @if (post.Status == "Draft")
                                    {
                                        <form method="post" style="display:inline;">
                                            <input type="hidden" name="Id" value="@post.Id" />
                                            <input type="hidden" name="action" value="publish" />
                                            <button type="submit" class="btn btn-success" title="Publish" onclick="return confirm('Publish this post live?')"><i class="bi bi-send"></i></button>
                                        </form>
                                    }
                                    else if (post.Status == "Published")
                                    {
                                        <form method="post" style="display:inline;">
                                            <input type="hidden" name="Id" value="@post.Id" />
                                            <input type="hidden" name="action" value="unpublish" />
                                            <button type="submit" class="btn btn-secondary" title="Revert to Draft"><i class="bi bi-archive"></i></button>
                                        </form>
                                    }

                                    @if (post.Status != "Deleted")
                                    {
                                        <form method="post" style="display:inline;">
                                            <input type="hidden" name="Id" value="@post.Id" />
                                            <input type="hidden" name="action" value="delete" />
                                            <button type="submit" class="btn btn-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this post?')"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            <i class="bi bi-inbox display-6 d-block mb-2"></i>
                            No posts found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Add Post Modal -->
        <div class="modal fade" id="addPostModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Create New Post</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                        <form method="post">
                            <input type="hidden" name="action" value="create" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Title</label>
                                <input type="text" class="form-control" name="Title" placeholder="Enter post title" required>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Category</label>
                                    <select class="form-select" name="Category" required>
                                        <option value="">Select Category</option>
                                        <option value="Notice">Notice</option>
                                        <option value="Blog">Blog</option>
                                        <option value="Training">Training</option>
                                        <option value="Announcement">Announcement</option>
                                        <option value="Policy">Policy</option>
                                        <option value="Event">Event</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Target Audience (Role Access)</label>
                                    <select class="form-select" name="TargetRole">
                                        <option value="All">All Users (Public)</option>
                                        <option value="staff">Staff Members Only</option>
                                        <option value="cleaner">Cleaners Only</option>
                                        <option value="wereda_mahberat">Wereda Mahberat Only</option>
                                        <option value="dispatch_officer">Dispatch Officers Only</option>
                                        <option value="driver">Drivers Only</option>
                                        <option value="manager">Managers Only</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Priority Level</label>
                                    <select class="form-select" name="Priority">
                                        <option value="Normal">Normal</option>
                                        <option value="Medium">Medium</option>
                                        <option value="High">High / Critical</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="IsPinned" id="addIsPinned" value="true">
                                        <label class="form-check-label" for="addIsPinned">
                                            <strong>Pin Post to Top</strong> (Sticky Notice)
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Link to Training Record (Optional)</label>
                                <select class="form-select" name="TrainingId">
                                    <option value="">None / Not a Training Post</option>
                                    @if (Model.TrainingList != null)
                                    {
                                        @foreach (var tr in Model.TrainingList)
                                        {
                                            <option value="@tr.Id">@tr.Title</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Content Body</label>
                                <textarea class="form-control" name="PostContent" rows="6" placeholder="Write your post content here..." required></textarea>
                            </div>
                            <div class="modal-footer px-0 pb-0">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Publish Post</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Post Modal -->
        <div class="modal fade" id="editPostModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square text-success me-2"></i>Modify Post</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form method="post">
                            <input type="hidden" name="action" value="update" />
                            <input type="hidden" name="Id" id="editPostId" />
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Title</label>
                                <input type="text" class="form-control" name="Title" id="editPostTitle" required>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Category</label>
                                    <select class="form-select" name="Category" id="editPostCategory" required>
                                        <option value="Notice">Notice</option>
                                        <option value="Blog">Blog</option>
                                        <option value="Training">Training</option>
                                        <option value="Announcement">Announcement</option>
                                        <option value="Policy">Policy</option>
                                        <option value="Event">Event</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Target Audience (Role Access)</label>
                                    <select class="form-select" name="TargetRole" id="editPostTargetRole">
                                        <option value="All">All Users (Public)</option>
                                        <option value="staff">Staff Members Only</option>
                                        <option value="cleaner">Cleaners Only</option>
                                        <option value="wereda_mahberat">Wereda Mahberat Only</option>
                                        <option value="dispatch_officer">Dispatch Officers Only</option>
                                        <option value="driver">Drivers Only</option>
                                        <option value="manager">Managers Only</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Priority Level</label>
                                    <select class="form-select" name="Priority" id="editPostPriority">
                                        <option value="Normal">Normal</option>
                                        <option value="Medium">Medium</option>
                                        <option value="High">High / Critical</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="IsPinned" id="editPostIsPinned" value="true">
                                        <label class="form-check-label" for="editPostIsPinned">
                                            <strong>Pin Post to Top</strong> (Sticky Notice)
                                        </label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Link to Training Record (Optional)</label>
                                    <select class="form-select" name="TrainingId" id="editPostTrainingId">
                                        <option value="">None / Not a Training Post</option>
                                        @if (Model.TrainingList != null)
                                        {
                                            @foreach (var tr in Model.TrainingList)
                                            {
                                                <option value="@tr.Id">@tr.Title</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Publication Status</label>
                                    <select class="form-select" name="Status" id="editPostStatus">
                                        <option value="Draft">Draft</option>
                                        <option value="Published">Published</option>
                                        <option value="Deleted">Deleted</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Content Body</label>
                                <textarea class="form-control" name="PostContent" id="editPostContent" rows="6" required></textarea>
                            </div>
                            
                            <div class="modal-footer px-0 pb-0">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-success"><i class="bi bi-save-fill me-1"></i>Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(link) {
            link.addEventListener('click', function() { if (window.innerWidth < 992) toggleSidebar(); });
        });

        // Auto-close sidebar dropdowns when clicking other links
        const navLinks = document.querySelectorAll('.sidebar .nav-link:not([data-bs-toggle="collapse"])');
        navLinks.forEach(link => {
            link.addEventListener('click', function() {
                const collapses = document.querySelectorAll('.sidebar .collapse.show');
                collapses.forEach(c => {
                    const bsCollapse = bootstrap.Collapse.getInstance(c);
                    if (bsCollapse) {
                        bsCollapse.hide();
                    }
                });
            });
        });

        // Edit Post Modal populating
        document.querySelectorAll('.btn-edit-post').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const title = this.getAttribute('data-title');
                const category = this.getAttribute('data-category');
                const content = this.getAttribute('data-content');
                const status = this.getAttribute('data-status');
                const trainingid = this.getAttribute('data-trainingid');
                const ispinned = this.getAttribute('data-ispinned') === 'true';
                const priority = this.getAttribute('data-priority');
                const targetrole = this.getAttribute('data-targetrole');

                document.getElementById('editPostId').value = id;
                document.getElementById('editPostTitle').value = title;
                document.getElementById('editPostCategory').value = category || 'Notice';
                document.getElementById('editPostContent').value = content;
                document.getElementById('editPostStatus').value = status || 'Draft';
                document.getElementById('editPostTrainingId').value = trainingid || '';
                document.getElementById('editPostIsPinned').checked = ispinned;
                document.getElementById('editPostPriority').value = priority || 'Normal';
                document.getElementById('editPostTargetRole').value = targetrole || 'All';

                // Show Edit Modal
                const editModal = new bootstrap.Modal(document.getElementById('editPostModal'));
                editModal.show();
            });
        });
    </script>
</body>
</html>
