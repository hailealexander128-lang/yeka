@page
@model CleaningManagmentSystem.Pages.Dashboard.SuperAdmin.OutsourceCompanyModel
@{
    Layout = null;
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole")?.ToLower();
    if (userName == null) { Response.Redirect("/Login"); return; }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Outsource Company - Super Admin - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>
    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-left me-2"></i>Logout</a>
        </div>
    </nav>
    <nav id="sidebarMenu" class="sidebar d-lg-none">
        @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
    </nav>
    <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
        @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
    </nav>

    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2"><i class="bi bi-building me-2"></i>Outsource Company Management</h1>
            <span class="badge bg-danger">Super Admin</span>
        </div>

        <!-- Success/Error Messages -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Search and Add -->
        <div class="row mb-4">
            <div class="col-md-8">
                <form method="get" class="d-flex">
                    <div class="input-group">
                        <input type="text" class="form-control" name="searchQuery" placeholder="Search companies..." value="@Model.SearchQuery" />
                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                        @if (!string.IsNullOrEmpty(Model.SearchQuery))
                        {
                            <a href="/Dashboard/SuperAdmin/OutsourceCompany" class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i>
                            </a>
                        }
                    </div>
                </form>
            </div>
            <div class="col-md-4 text-end">
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCompanyModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Company
                </button>
            </div>
        </div>

        <!-- Companies Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Company Name</th>
                                <th>Contact Person</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Contract Start</th>
                                <th>Contract End</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Companies.Any())
                            {
                                foreach (var company in Model.Companies)
                                {
                                    <tr>
                                        <td>@company.Id</td>
                                        <td><strong>@company.CompanyName</strong></td>
                                        <td>@company.ContactPerson</td>
                                        <td>@company.Phone</td>
                                        <td>@company.Email</td>
                                        <td>@(company.ContractStartDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                        <td>@(company.ContractEndDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                        <td>
                                            @if (company.Status == "Active")
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewModal-@company.Id" title="View">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editModal-@company.Id" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@company.Id" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="bi bi-building display-4"></i><br>
                                        No companies found
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Add Company Modal -->
    <div class="modal fade" id="addCompanyModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add Outsource Company</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="action" value="create" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Company Name *</label>
                                <input type="text" class="form-control" name="CompanyName" required placeholder="Enter company name" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Contact Person *</label>
                                <input type="text" class="form-control" name="ContactPerson" required placeholder="Enter contact person" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Phone *</label>
                                <input type="tel" class="form-control" name="Phone" required placeholder="+251911234567" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Email</label>
                                <input type="email" class="form-control" name="Email" placeholder="company@email.et" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">License Number</label>
                                <input type="text" class="form-control" name="LicenseNumber" placeholder="Business license number" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Contract Start Date *</label>
                                <input type="date" class="form-control" name="ContractStartDate" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Contract End Date</label>
                                <input type="date" class="form-control" name="ContractEndDate" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Status</label>
                                <select class="form-select" name="Status">
                                    <option value="Active" selected>Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Services Provided</label>
                                <textarea class="form-control" name="ServicesProvided" rows="3" placeholder="Describe services provided..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Company</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- View, Edit, Delete Modals for each company -->
    @foreach (var company in Model.Companies)
    {
        <!-- View Modal -->
        <div class="modal fade" id="viewModal-@company.Id" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-building me-2"></i>Company Details</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <table class="table table-borderless">
                            <tr><th width="40%">Company Name:</th><td><strong>@company.CompanyName</strong></td></tr>
                            <tr><th>Contact Person:</th><td>@company.ContactPerson</td></tr>
                            <tr><th>Phone:</th><td>@company.Phone</td></tr>
                            <tr><th>Email:</th><td>@company.Email</td></tr>
                            <tr><th>License Number:</th><td>@company.LicenseNumber</td></tr>
                            <tr><th>Contract Start:</th><td>@(company.ContractStartDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>
                            <tr><th>Contract End:</th><td>@(company.ContractEndDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>
                            <tr><th>Status:</th>
                                <td>
                                    @if (company.Status == "Active")
                                    { <span class="badge bg-success">Active</span> }
                                    else
                                    { <span class="badge bg-secondary">Inactive</span> }
                                </td>
                            </tr>
                            <tr><th>Services:</th><td>@(string.IsNullOrEmpty(company.ServicesProvided) ? "-" : company.ServicesProvided)</td></tr>
                        </table>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Modal -->
        <div class="modal fade" id="editModal-@company.Id" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <form method="post">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Company</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="action" value="update" />
                            <input type="hidden" name="Id" value="@company.Id" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Company Name *</label>
                                    <input type="text" class="form-control" name="CompanyName" value="@company.CompanyName" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contact Person *</label>
                                    <input type="text" class="form-control" name="ContactPerson" value="@company.ContactPerson" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Phone *</label>
                                    <input type="tel" class="form-control" name="Phone" value="@company.Phone" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Email</label>
                                    <input type="email" class="form-control" name="Email" value="@company.Email" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">License Number</label>
                                    <input type="text" class="form-control" name="LicenseNumber" value="@company.LicenseNumber" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract Start Date *</label>
                                    <input type="date" class="form-control" name="ContractStartDate" value="@(company.ContractStartDate?.ToString("yyyy-MM-dd"))" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract End Date</label>
                                    <input type="date" class="form-control" name="ContractEndDate" value="@(company.ContractEndDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Status</label>
                                    <select class="form-select" name="Status">
                                        <option value="Active" selected="@(company.Status == "Active" ? "selected" : null)">Active</option>
                                        <option value="Inactive" selected="@(company.Status == "Inactive" ? "selected" : null)">Inactive</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold">Services Provided</label>
                                    <textarea class="form-control" name="ServicesProvided" rows="3">@company.ServicesProvided</textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Update Company</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Delete Confirmation Modal -->
        <div class="modal fade" id="deleteModal-@company.Id" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <form method="post">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Delete Company</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center">
                            <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                            <p class="mt-3">Are you sure you want to delete <strong>@company.CompanyName</strong>?</p>
                            <p class="text-muted small">This action cannot be undone.</p>
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="Id" value="@company.Id" />
                        </div>
                        <div class="modal-footer justify-content-center">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(link) {
            link.addEventListener('click', function() { if (window.innerWidth < 992) toggleSidebar(); });
        });
    </script>
</body>
</html>
