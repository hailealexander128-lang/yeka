@page
@{
    var userName = HttpContext.Session.GetString("UserName");
    
    if (userName == null)
    {
        Response.Redirect("/Login");
        return;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Task - Driver - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/Driver/Task"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/Driver/Task"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>

    <nav id="sidebarMenu" class="sidebar d-lg-none">
        @await Html.PartialAsync("~/Pages/Dashboard/Driver/_Sidebar.cshtml")
    </nav>
    <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
        @await Html.PartialAsync("~/Pages/Dashboard/Driver/_Sidebar.cshtml")
    </nav>

    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2">Driver Tasks</h1>
            <span class="badge bg-primary">Driver</span>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-clipboard-check display-4 text-success"></i>
                        <h3 class="mt-2">15</h3>
                        <p>Completed Tasks</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-hourglass-split display-4 text-warning"></i>
                        <h3 class="mt-2">5</h3>
                        <p>Pending Tasks</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-truck display-4 text-info"></i>
                        <h3 class="mt-2">2</h3>
                        <p>Active Deliveries</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h4>All Tasks</h4>
            <table class="table table-striped">
                <thead>
                    <tr><th>Task ID</th><th>Description</th><th>Destination</th><th>Priority</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr><td>TSK-001</td><td>Pickup Cleaning Supplies</td><td>Main Warehouse</td><td><span class="badge bg-danger">High</span></td><td><span class="badge bg-success">Completed</span></td></tr>
                    <tr><td>TSK-002</td><td>Transport Staff</td><td>Yeka Sub-City</td><td><span class="badge bg-warning">Medium</span></td><td><span class="badge bg-success">Completed</span></td></tr>
                    <tr><td>TSK-003</td><td>Equipment Delivery</td><td>Kirkos Office</td><td><span class="badge bg-warning">Medium</span></td><td><span class="badge bg-primary">In Progress</span></td></tr>
                    <tr><td>TSK-004</td><td>Waste Disposal</td><td>Central Dump</td><td><span class="badge bg-secondary">Low</span></td><td><span class="badge bg-warning">Pending</span></td></tr>
                </tbody>
            </table>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.innerWidth < 992) toggleSidebar();
            });
        });
    </script>
</body>
</html>