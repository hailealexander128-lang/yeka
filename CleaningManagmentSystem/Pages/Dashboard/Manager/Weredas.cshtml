@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.WeredasModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Weredas - Manager - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/Manager"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @HttpContext.Session.GetString("UserName")</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/Manager"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>

    <nav id="sidebarMenu" class="sidebar d-lg-none">
        @await Html.PartialAsync("~/Pages/Dashboard/Manager/_Sidebar.cshtml")
    </nav>
    <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
        @await Html.PartialAsync("~/Pages/Dashboard/Manager/_Sidebar.cshtml")
    </nav>

    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5" style="margin-top: 56px;">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2"><i class="bi bi-geo-alt me-2"></i>Wereda Management</h1>
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addWeredaModal">
                <i class="bi bi-plus-circle me-2"></i>Add Wereda
            </button>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white pb-0">
                <h5 class="card-title mt-2"><i class="bi bi-list-ul me-2"></i>Weredas Directory</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Subcity</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var wereda in Model.Weredas)
                            {
                                <tr>
                                    <td>@wereda.Id</td>
                                    <td>
                                        <strong>@wereda.Name</strong>
                                        <br><small class="text-muted">@wereda.Description</small>
                                    </td>
                                    <td>@wereda.Subcity</td>
                                    <td>
                                        @if (wereda.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>@wereda.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editWeredaModal"
                                                data-id="@wereda.Id" data-name="@wereda.Name" data-description="@wereda.Description"
                                                data-subcity="@wereda.Subcity" data-isactive="@wereda.IsActive">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteWeredaModal"
                                                data-id="@wereda.Id" data-name="@wereda.Name">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                             }
                         </tbody>
                     </table>
                 </div>
             </div>
         </div>
     </main>
    <!-- Add Wereda Modal -->
    <div class="modal fade" id="addWeredaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                 <form method="post" action="/Dashboard/Manager/Weredas?handler=Add">
                     @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Add New Wereda</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" name="Name" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Subcity</label>
                                <input type="text" class="form-control" name="Subcity" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="Description" rows="2"></textarea>
                            </div>
                            <div class="col-md-12">
                                <div class="form-check mt-2">
                                    <input type="checkbox" class="form-check-input" name="IsActive" id="addIsActive" value="true" checked />
                                    <label class="form-check-label" for="addIsActive">Active</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Wereda</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Wereda Modal -->
    <div class="modal fade" id="editWeredaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                 <form method="post" action="/Dashboard/Manager/Weredas?handler=Update">
                     @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Wereda</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" id="editId" />
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" name="Name" id="editName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="Description" id="editDescription" rows="2"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subcity</label>
                            <input type="text" class="form-control" name="Subcity" id="editSubcity" />
                        </div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" name="IsActive" id="editIsActive" />
                            <label class="form-check-label" for="editIsActive">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Wereda Modal -->
    <div class="modal fade" id="deleteWeredaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                 <form method="post" action="/Dashboard/Manager/Weredas?handler=Delete">
                     @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" id="deleteId" />
                        <p>Are you sure you want to delete <strong id="deleteName"></strong>?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.innerWidth < 992) toggleSidebar();
            });
        });

        // Edit modal populate
        $('#editWeredaModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            $('#editId').val(button.data('id'));
            $('#editName').val(button.data('name'));
            $('#editDescription').val(button.data('description'));
            $('#editSubcity').val(button.data('subcity'));
            if (button.data('isactive')) {
                $('#editIsActive').prop('checked', true);
            } else {
                $('#editIsActive').prop('checked', false);
            }
        });

        // Delete modal populate
        $('#deleteWeredaModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            $('#deleteId').val(button.data('id'));
            $('#deleteName').text(button.data('name'));
        });
    </script>
</body>
</html>
