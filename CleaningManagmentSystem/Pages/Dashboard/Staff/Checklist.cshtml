@page
@{
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole");
    
    if (userName == null)
    {
        Response.Redirect("/Login");
        return;
    }
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    ViewData["Title"] = "Task Checklist Report";
}

<div class="main-content p-4">
    <div class="container-fluid">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h4 mb-0">
                    <i class="bi bi-check-square me-2"></i>Task Checklist Report
                </h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/Dashboard/Staff/Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Checklist</li>
                    </ol>
                </nav>
            </div>
            <div>
                <button class="btn btn-primary me-2" onclick="generateChecklistReport()"><i class="bi bi-search me-1"></i> Show Report</button>
                <button class="btn btn-outline-secondary" onclick="clearReport()"><i class="bi bi-arrow-counterclockwise me-1"></i> Clear</button>
            </div>
        </div>

        <div class="row g-4">
            <!-- Column 1: Report List -->
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold">Report List</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                            <label class="list-group-item border-0 d-flex align-items-center gap-2">
                                <input class="form-check-input me-1" type="radio" name="reportList" value="Daily Task Summary" checked onchange="generateChecklistReport()">
                                Daily Task Summary
                            </label>
                            <label class="list-group-item border-0 d-flex align-items-center gap-2">
                                <input class="form-check-input me-1" type="radio" name="reportList" value="Weekly Cleaning Checklist" onchange="generateChecklistReport()">
                                Weekly Cleaning Checklist
                            </label>
                            <label class="list-group-item border-0 d-flex align-items-center gap-2">
                                <input class="form-check-input me-1" type="radio" name="reportList" value="Monthly Maintenance Tasks" onchange="generateChecklistReport()">
                                Monthly Maintenance Tasks
                            </label>
                            <label class="list-group-item border-0 d-flex align-items-center gap-2">
                                <input class="form-check-input me-1" type="radio" name="reportList" value="Admin Tasks Summary" onchange="generateChecklistReport()">
                                Admin Tasks Summary
                            </label>
                            <label class="list-group-item border-0 d-flex align-items-center gap-2">
                                <input class="form-check-input me-1" type="radio" name="reportList" value="Overdue Tasks Report" onchange="generateChecklistReport()">
                                Overdue Tasks Report
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Column 2: Report Types -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold">Report Types</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" id="reportTypesList" style="max-height: 500px; overflow-y: auto;">
                            <button class="list-group-item list-group-item-action border-0 d-flex align-items-center gap-2 active" onclick="selectType(this, 'status')">
                                <i class="bi bi-file-earmark-text"></i> Summary By Status
                            </button>
                            <button class="list-group-item list-group-item-action border-0 d-flex align-items-center gap-2" onclick="selectType(this, 'priority')">
                                <i class="bi bi-file-earmark-text text-muted"></i> Summary By Priority
                            </button>
                            <button class="list-group-item list-group-item-action border-0 d-flex align-items-center gap-2" onclick="selectType(this, 'date')">
                                <i class="bi bi-file-earmark-text text-muted"></i> Summary By Date
                            </button>
                            <button class="list-group-item list-group-item-action border-0 d-flex align-items-center gap-2" onclick="selectType(this, 'detailed')">
                                <i class="bi bi-file-earmark-text text-muted"></i> Detailed Task List
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Column 3: Report Criteria -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold">Report Criteria</h6>
                    </div>
                    <div class="card-body p-4">
                        <form id="criteriaForm">
                            <div class="mb-3">
                                <label class="form-label text-muted small">Date Criteria</label>
                                <select class="form-select">
                                    <option>By Due Date</option>
                                    <option>By Creation Date</option>
                                    <option>By Completion Date</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">Date Range Option</label>
                                <select class="form-select" onchange="toggleCustomDateRange(this)" id="dateRangeOption">
                                    <option value="today">Today</option>
                                    <option value="yesterday">Yesterday</option>
                                    <option value="this-week">This Week</option>
                                    <option value="this-month" selected>This Month</option>
                                    <option value="this-year">This Year</option>
                                    <option value="custom">Custom Range</option>
                                </select>
                            </div>
                            <div class="mb-3 custom-date-range-container" style="display: none;">
                                <label class="form-label text-muted small">Date Range</label>
                                <div class="input-group">
                                    <input type="date" class="form-control" value="@DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")">
                                    <span class="input-group-text">-</span>
                                    <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">Task Status</label>
                                <select class="form-select" id="statusSelect" onchange="generateChecklistReport()">
                                    <option value="all">All Statuses</option>
                                    <option value="Completed">Completed</option>
                                    <option value="InProgress">In Progress</option>
                                    <option value="Pending">Pending</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">Priority</label>
                                <select class="form-select" id="prioritySelect" onchange="generateChecklistReport()">
                                    <option value="all">All Priorities</option>
                                    <option value="High">High</option>
                                    <option value="Medium">Medium</option>
                                    <option value="Low">Low</option>
                                </select>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Premium ERP Printable Report Viewer -->
        <div id="generatedReportSection" class="mt-5 fade-in-up" style="display: none;">
            <div class="document-viewer" id="pdfViewerContainer">
                <!-- Viewer Toolbar -->
                <div class="viewer-toolbar d-flex flex-wrap gap-2 align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-light border" disabled><i class="bi bi-chevron-left"></i></button>
                        <span class="small fw-semibold">1 of 1</span>
                        <button class="btn btn-sm btn-light border" disabled><i class="bi bi-chevron-right"></i></button>
                        <div class="vr mx-2"></div>
                        <button class="btn btn-sm btn-light border"><i class="bi bi-columns-gap"></i></button>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-light border" onclick="changeZoom(-0.1)"><i class="bi bi-dash"></i></button>
                        <select class="form-select form-select-sm py-0" id="zoomSelect" onchange="applyZoomPreset(this)" style="width: auto; height: 28px;">
                            <option value="1.0">Whole Page</option>
                            <option value="1.2">Page Width</option>
                            <option value="0.8">80%</option>
                            <option value="1.0" selected>100%</option>
                            <option value="1.2">120%</option>
                        </select>
                        <button class="btn btn-sm btn-light border" onclick="changeZoom(0.1)"><i class="bi bi-plus"></i></button>
                    </div>
                    <div class="d-flex align-items-center gap-2 ms-auto">
                        <button class="btn btn-sm btn-light border" onclick="window.print()" title="Print Report"><i class="bi bi-printer text-dark"></i></button>
                        <button class="btn btn-sm btn-light border" onclick="openReportInNewTab()" title="Open in New Tab"><i class="bi bi-box-arrow-up-right text-dark"></i></button>
                        <button class="btn btn-sm btn-light border" onclick="exportReportToCSV()" title="Download CSV"><i class="bi bi-file-earmark-arrow-down text-dark"></i></button>
                        <button class="btn btn-sm btn-light border" onclick="exportReportToCSV()" title="Export Excel"><i class="bi bi-file-earmark-excel text-success"></i></button>
                        <div class="vr mx-1"></div>
                        <div class="input-group input-group-sm d-none d-md-flex" style="width: 150px;">
                            <input type="text" class="form-control" id="tableSearch" onkeyup="filterReportTable()" placeholder="Search on page...">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                        </div>
                        <button class="btn btn-sm btn-light border" onclick="toggleFullscreen()" title="Fullscreen"><i class="bi bi-fullscreen"></i></button>
                    </div>
                </div>

                <!-- Scroll Wrapper for zoomable sheet -->
                <div class="sheet-scroll-wrapper" style="overflow-x: auto; padding: 20px 0; background: #e9e9e9;">
                    <!-- Printable A4 Document Sheet -->
                    <div class="viewer-sheet" id="printableSheet">
                        <!-- Top Header Row -->
                        <div class="d-flex justify-content-between align-items-start border-bottom pb-2 mb-3">
                            <div>
                                <div class="sheet-header-title text-uppercase">YEKA CLEANING MANAGEMENT SYSTEM</div>
                                <div class="sheet-meta-text" id="docCriteriaMeta">
                                    Task Checklist Report, Report filtered by data criteria: at the day of @DateTime.Now.ToString("MM/dd/yyyy"), Status = All, Void State = Active
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="sheet-header-date" id="docDateRight">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
                                <div class="sheet-report-box mt-2 text-uppercase" id="docReportTypeBox">Categorized And Summarized By Status</div>
                            </div>
                        </div>

                        <!-- Structured grouped table layout matching Red Cloud style -->
                        <table class="sheet-table" id="reportTableData">
                            <thead id="tableReportHeader">
                                <!-- Generated Dynamically -->
                            </thead>
                            <tbody id="tableReportBody">
                                <!-- Generated Dynamically -->
                            </tbody>
                        </table>

                        <!-- Summary Box matching exact bottom calculation grid -->
                        <table class="sheet-summary-box" id="summaryBoxTable">
                            <!-- Generated Dynamically -->
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    let currentZoom = 1.0;
    let selectedReportType = 'status';

    // Task Checklist Sample Records
    const checklistData = [
        {
            category: "COMPLETED TASKS",
            subcategory: "Subcity Residential Tasks",
            code: "TS-RES-04",
            detail: "Complete residential cleaning at Bole Hub Area",
            qty: 1,
            rate: 49998.79,
            status: "Completed",
            priority: "High",
            date: "@DateTime.Now.ToString("yyyy-MM-dd")"
        },
        {
            category: "IN PROGRESS TASKS",
            subcategory: "Warehouse Support Tasks",
            code: "TS-WAR-09",
            detail: "Restock cleaning supplies (Main Warehouse)",
            qty: 1,
            rate: 4326.35,
            status: "InProgress",
            priority: "Medium",
            date: "@DateTime.Now.ToString("yyyy-MM-dd")"
        },
        {
            category: "PENDING TASKS",
            subcategory: "Administration Audits",
            code: "TS-ADM-12",
            detail: "Submit weekly audit report to supervisor",
            qty: 2,
            rate: 22336.00,
            status: "Pending",
            priority: "Low",
            date: "@DateTime.Now.AddDays(-1).ToString("yyyy-MM-dd")"
        }
    ];

    function toggleCustomDateRange(selectElement) {
        const container = selectElement.closest('form').querySelector('.custom-date-range-container');
        if (selectElement.value === 'custom') {
            container.style.display = 'block';
        } else {
            container.style.display = 'none';
        }
    }

    function selectType(button, type) {
        const list = button.parentElement;
        list.querySelectorAll('button').forEach(btn => {
            btn.classList.remove('active');
            btn.querySelector('i').className = 'bi bi-file-earmark-text text-muted';
        });
        button.classList.add('active');
        button.querySelector('i').className = 'bi bi-file-earmark-text';
        selectedReportType = type;

        generateChecklistReport();
    }

    function generateChecklistReport() {
        const reportSection = document.getElementById('generatedReportSection');
        reportSection.style.display = 'block';

        const selectedRadio = document.querySelector('input[name="reportList"]:checked');
        const reportListName = selectedRadio ? selectedRadio.value : "Daily Task Summary";

        const activeTypeButton = document.querySelector('#reportTypesList button.active');
        const reportTypeName = activeTypeButton ? activeTypeButton.textContent.trim() : "Categorized By Status";

        const rangeOpt = document.getElementById('dateRangeOption');
        const rangeText = rangeOpt.options[rangeOpt.selectedIndex].text;

        const statusVal = document.getElementById('statusSelect').value;
        const priorityVal = document.getElementById('prioritySelect').value;

        document.getElementById('docReportTypeBox').innerText = reportTypeName;
        document.getElementById('docCriteriaMeta').innerText = `${reportListName}, Criteria: Date = ${rangeText}, Status = ${statusVal.toUpperCase()}, Priority = ${priorityVal}`;

        // Filtering
        let filtered = checklistData;
        if (statusVal !== "all") {
            filtered = filtered.filter(item => item.status === statusVal);
        }
        if (priorityVal !== "all") {
            filtered = filtered.filter(item => item.priority === priorityVal);
        }

        const thead = document.getElementById('tableReportHeader');
        const tbody = document.getElementById('tableReportBody');
        thead.innerHTML = "";
        tbody.innerHTML = "";

        if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted">No records matching the filter criteria were found.</td></tr>`;
            document.getElementById('summaryBoxTable').innerHTML = "";
            return;
        }

        let subtotalAccumulator = 0;

        if (selectedReportType === 'status') {
            thead.innerHTML = `
                <tr>
                    <th style="width: 25%; text-align: left;">Category / Sub Category</th>
                    <th style="width: 15%; text-align: left;">Task Code</th>
                    <th style="width: 35%; text-align: left;">Task Detail / Area</th>
                    <th style="width: 8%; text-align: center;">Qty (Tasks)</th>
                    <th style="width: 8%; text-align: right;">Target Weight</th>
                    <th style="width: 9%; text-align: right;">Weighted Total</th>
                </tr>
            `;

            let categories = [...new Set(filtered.map(x => x.category))];
            categories.forEach(cat => {
                tbody.innerHTML += `
                    <tr class="sheet-category-row">
                        <td colspan="6" class="text-uppercase py-1 px-2">${cat}</td>
                    </tr>
                `;

                let catItems = filtered.filter(x => x.category === cat);
                let subcats = [...new Set(catItems.map(x => x.subcategory))];

                let categorySum = 0;
                let categoryQtySum = 0;

                subcats.forEach(sub => {
                    tbody.innerHTML += `
                        <tr class="sheet-subcategory-row">
                            <td colspan="6" class="py-1 px-3 text-uppercase">${sub}</td>
                        </tr>
                    `;

                    let subItems = catItems.filter(x => x.subcategory === sub);
                    let subSum = 0;
                    let subQtySum = 0;

                    subItems.forEach(item => {
                        let totalAmount = item.qty * item.rate;
                        subSum += totalAmount;
                        subQtySum += item.qty;

                        tbody.innerHTML += `
                            <tr>
                                <td></td>
                                <td>${item.code}</td>
                                <td>${item.detail} <span class="badge ${item.status === 'Completed' ? 'bg-success' : item.status === 'InProgress' ? 'bg-warning text-dark' : 'bg-secondary'} ms-1" style="font-size:9px; padding:2px 4px;">${item.status}</span></td>
                                <td class="text-center">${item.qty.toFixed(2)}</td>
                                <td class="text-end">${item.rate.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                                <td class="text-end">${totalAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                            </tr>
                        `;
                    });

                    categorySum += subSum;
                    categoryQtySum += subQtySum;

                    tbody.innerHTML += `
                        <tr class="sheet-total-row">
                            <td colspan="3" class="text-end fw-bold">${sub} Total</td>
                            <td class="text-center">${subQtySum.toFixed(2)}</td>
                            <td class="text-end">-</td>
                            <td class="text-end">${subSum.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        </tr>
                    `;
                });

                subtotalAccumulator += categorySum;

                tbody.innerHTML += `
                    <tr class="sheet-total-row bg-light">
                        <td colspan="3" class="text-end fw-bold text-teal">${cat} Total</td>
                        <td class="text-center text-teal">${categoryQtySum.toFixed(2)}</td>
                        <td class="text-end">-</td>
                        <td class="text-end text-teal">${categorySum.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    </tr>
                `;
            });

        } else if (selectedReportType === 'priority') {
            thead.innerHTML = `
                <tr>
                    <th style="width: 25%; text-align: left;">Priority</th>
                    <th style="width: 15%; text-align: left;">Task Code</th>
                    <th style="width: 35%; text-align: left;">Task Detail / Area</th>
                    <th style="width: 8%; text-align: center;">Qty (Tasks)</th>
                    <th style="width: 8%; text-align: right;">Target Weight</th>
                    <th style="width: 9%; text-align: right;">Weighted Total</th>
                </tr>
            `;

            let priorities = [...new Set(filtered.map(x => x.priority))];
            priorities.forEach(p => {
                tbody.innerHTML += `
                    <tr class="sheet-category-row">
                        <td colspan="6" class="text-uppercase py-1 px-2">PRIORITY: ${p.toUpperCase()}</td>
                    </tr>
                `;

                let priorityItems = filtered.filter(x => x.priority === p);
                let prioritySum = 0;
                let priorityQtySum = 0;

                priorityItems.forEach(item => {
                    let totalAmount = item.qty * item.rate;
                    prioritySum += totalAmount;
                    priorityQtySum += item.qty;

                    tbody.innerHTML += `
                        <tr>
                            <td></td>
                            <td>${item.code}</td>
                            <td>${item.detail} <span class="badge ${item.status === 'Completed' ? 'bg-success' : 'bg-secondary'} ms-1" style="font-size:9px;">${item.status}</span></td>
                            <td class="text-center">${item.qty.toFixed(2)}</td>
                            <td class="text-end">${item.rate.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                            <td class="text-end">${totalAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        </tr>
                    `;
                });

                subtotalAccumulator += prioritySum;

                tbody.innerHTML += `
                    <tr class="sheet-total-row">
                        <td colspan="3" class="text-end fw-bold">Priority ${p} Total</td>
                        <td class="text-center">${priorityQtySum.toFixed(2)}</td>
                        <td class="text-end">-</td>
                        <td class="text-end">${prioritySum.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    </tr>
                `;
            });

        } else if (selectedReportType === 'date') {
            thead.innerHTML = `
                <tr>
                    <th style="width: 25%; text-align: left;">Date</th>
                    <th style="width: 15%; text-align: left;">Task Code</th>
                    <th style="width: 35%; text-align: left;">Task Detail / Area</th>
                    <th style="width: 8%; text-align: center;">Qty (Tasks)</th>
                    <th style="width: 8%; text-align: right;">Target Weight</th>
                    <th style="width: 9%; text-align: right;">Weighted Total</th>
                </tr>
            `;

            let dates = [...new Set(filtered.map(x => x.date))];
            dates.forEach(d => {
                tbody.innerHTML += `
                    <tr class="sheet-category-row">
                        <td colspan="6" class="text-uppercase py-1 px-2">DATE: ${d}</td>
                    </tr>
                `;

                let dateItems = filtered.filter(x => x.date === d);
                let dateSum = 0;
                let dateQtySum = 0;

                dateItems.forEach(item => {
                    let totalAmount = item.qty * item.rate;
                    dateSum += totalAmount;
                    dateQtySum += item.qty;

                    tbody.innerHTML += `
                        <tr>
                            <td></td>
                            <td>${item.code}</td>
                            <td>${item.detail} <small class="text-muted">(${item.category})</small></td>
                            <td class="text-center">${item.qty.toFixed(2)}</td>
                            <td class="text-end">${item.rate.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                            <td class="text-end">${totalAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        </tr>
                    `;
                });

                subtotalAccumulator += dateSum;

                tbody.innerHTML += `
                    <tr class="sheet-total-row">
                        <td colspan="3" class="text-end fw-bold">Date ${d} Total</td>
                        <td class="text-center">${dateQtySum.toFixed(2)}</td>
                        <td class="text-end">-</td>
                        <td class="text-end">${dateSum.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    </tr>
                `;
            });

        } else if (selectedReportType === 'detailed') {
            thead.innerHTML = `
                <tr>
                    <th style="width: 15%; text-align: left;">Date</th>
                    <th style="width: 15%; text-align: left;">Task Code</th>
                    <th style="width: 30%; text-align: left;">Task Detail / Subcategory</th>
                    <th style="width: 10%; text-align: center;">Qty (Tasks)</th>
                    <th style="width: 10%; text-align: right;">Target Weight</th>
                    <th style="width: 10%; text-align: center;">Priority</th>
                    <th style="width: 10%; text-align: right;">Total</th>
                </tr>
            `;

            filtered.forEach(item => {
                let totalAmount = item.qty * item.rate;
                subtotalAccumulator += totalAmount;

                tbody.innerHTML += `
                    <tr>
                        <td>${item.date}</td>
                        <td>${item.code}</td>
                        <td><strong>${item.detail}</strong><br><small class="text-muted">${item.subcategory}</small></td>
                        <td class="text-center">${item.qty.toFixed(2)}</td>
                        <td class="text-end">${item.rate.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        <td class="text-center"><span class="badge bg-dark">${item.priority}</span></td>
                        <td class="text-end fw-semibold">${totalAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    </tr>
                `;
            });
        }

        let tax = subtotalAccumulator * 0.15;
        let grand = subtotalAccumulator + tax;

        const summaryTable = document.getElementById('summaryBoxTable');
        summaryTable.innerHTML = `
            <tr>
                <td class="text-muted">Sub Total</td>
                <td class="text-end fw-bold">${subtotalAccumulator.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
            </tr>
            <tr>
                <td class="text-muted">Add. Charge</td>
                <td class="text-end">0.00</td>
            </tr>
            <tr>
                <td class="text-muted">Discount</td>
                <td class="text-end">0.00</td>
            </tr>
            <tr>
                <td class="text-muted">Total Tax (15% VAT)</td>
                <td class="text-end">${tax.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
            </tr>
            <tr class="grand-total">
