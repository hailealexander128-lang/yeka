    // Zoom Functions
    function changeZoom(factor) {
        currentZoom = Math.max(0.6, Math.min(1.5, currentZoom + factor));
        document.getElementById('zoomSelect').value = currentZoom.toFixed(1);
        applyZoom();
    }

    function applyZoomPreset(select) {
        currentZoom = parseFloat(select.value);
        applyZoom();
    }

    function applyZoom() {
        const sheet = document.getElementById('printableSheet');
        sheet.style.transform = `scale(${currentZoom})`;
        sheet.style.transformOrigin = `top center`;
        if (currentZoom > 1.0) {
            sheet.parentElement.style.paddingBottom = `${(currentZoom - 1.0) * 1000}px`;
        } else {
            sheet.parentElement.style.paddingBottom = `20px`;
        }
    }

    // Table Search
    function filterReportTable() {
        const query = document.getElementById('tableSearch').value.toLowerCase();
        const rows = document.querySelectorAll('#tableReportBody tr');
        rows.forEach(row => {
            if (row.classList.contains('sheet-category-row') || row.classList.contains('sheet-subcategory-row') || row.classList.contains('sheet-total-row')) {
                return;
            }
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(query) ? "" : "none";
        });
    }

    // CSV Exporter
    function exportReportToCSV() {
        let csv = [];
        const rows = document.querySelectorAll("#reportTableData tr");
        rows.forEach(row => {
            let cols = row.querySelectorAll("td, th");
            let rowData = [];
            cols.forEach(col => {
                let text = col.innerText.replace(/"/g, '""');
                rowData.push(`"${text}"`);
            });
            csv.push(rowData.join(","));
        });
        const csvFile = new Blob([csv.join("\n")], { type: "text/csv" });
        const downloadLink = document.createElement("a");
        downloadLink.download = `ChecklistReport_${new Date().toISOString().slice(0,10)}.csv`;
        downloadLink.href = window.URL.createObjectURL(csvFile);
        downloadLink.style.display = "none";
        document.body.appendChild(downloadLink);
        downloadLink.click();
        document.body.removeChild(downloadLink);
    }

    // Fullscreen Toggle
    // Fullscreen Toggle
    function toggleFullscreen() {
        const viewer = document.getElementById('pdfViewerContainer');
        if (!document.fullscreenElement) {
            viewer.requestFullscreen().catch(err => {
                alert(`Error: ${err.message}`);
            });
        } else {
            document.exitFullscreen();
        }
    }
