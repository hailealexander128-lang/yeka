@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.PostModel
@{
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole");
    if (userName == null) { Response.Redirect("/Login"); return; }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Announcements & Posts - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        .post-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .post-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 .75rem 1.5rem rgba(0,0,0,.1) !important;
        }
        .pinned-card {
            border-left: 4px solid #ef4444 !important;
        }
    </style>
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/Staff"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/Staff"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse" style="padding-top: 56px;">
                @await Html.PartialAsync("sidebar")
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                    <h1 class="h2 fw-bold text-dark"><i class="bi bi-postcard me-2 text-primary"></i>Announcements &amp; Posts</h1>
                    <span class="text-muted small">@Model.Posts?.Count posts available</span>
                </div>

                <div class="row g-4">
                    @if (Model.Posts != null && Model.Posts.Any())
                    {
                        @foreach (var post in Model.Posts)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 shadow-sm border-0 position-relative post-card @(post.IsPinned ? "pinned-card" : "")">
                                    @if (post.IsPinned)
                                    {
                                        <div class="position-absolute top-0 end-0 p-2">
                                            <span class="badge bg-danger"><i class="bi bi-pin-angle-fill me-1"></i>Pinned</span>
                                        </div>
                                    }
                                    <div class="card-body pb-0">
                                        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                            @{
                                                var catClass = post.Category switch
                                                {
                                                    "Notice"       => "bg-primary text-white",
                                                    "Blog"         => "bg-success text-white",
                                                    "Training"     => "bg-info text-dark",
                                                    "Announcement" => "bg-warning text-dark",
                                                    "Policy"       => "bg-dark text-white",
                                                    _              => "bg-secondary text-white"
                                                };
                                                var priorityBadgeClass = post.Priority switch
                                                {
                                                    "High"   => "bg-danger text-white",
                                                    "Medium" => "bg-warning text-dark",
                                                    _        => "bg-info text-dark"
                                                };
                                            }
                                            <span class="badge @catClass" style="font-size:0.75rem;">@post.Category</span>
                                            <span class="badge @priorityBadgeClass" style="font-size:0.75rem;">@post.Priority</span>
                                            @if (post.TrainingId.HasValue)
                                            {
                                                <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:0.7rem;"><i class="bi bi-mortarboard me-1"></i>Training</span>
                                            }
                                        </div>

                                        <h5 class="card-title fw-bold text-dark mb-2 @(post.IsPinned ? "pe-5" : "")">@post.Title</h5>

                                        <p class="card-text text-muted" style="font-size:0.9rem; line-height:1.6;">
                                            @if (post.Content.Length > 120)
                                            {
                                                @post.Content.Substring(0, 117)@("...")
                                            }
                                            else
                                            {
                                                @post.Content
                                            }
                                        </p>

                                        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                                            <small class="text-muted"><i class="bi bi-calendar-event me-1"></i>@post.CreatedAt?.ToString("MMM dd, yyyy")</small>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pt-2 pb-3">
                                        <button class="btn btn-sm btn-outline-primary w-100 py-1.5 fw-semibold btn-view-post"
                                                data-title="@post.Title"
                                                data-category="@post.Category"
                                                data-priority="@post.Priority"
                                                data-content="@post.Content"
                                                data-date="@post.CreatedAt?.ToString("MMM dd, yyyy")"
                                                data-trainingid="@(post.TrainingId?.ToString() ?? "")">
                                            <i class="bi bi-book-half me-1"></i>Read More
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center text-muted py-5">
                            <i class="bi bi-inbox display-4 d-block mb-3"></i>
                            <h5>No announcements yet</h5>
                            <p class="small">Check back later for updates from the admin team.</p>
                        </div>
                    }
                </div>
            </main>
        </div>
    </div>

    <!-- View Post Modal -->
    <div class="modal fade" id="viewPostModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-light">
                    <h5 class="modal-title fw-bold text-dark mb-0" id="modalPostTitle">Post Title</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex gap-2 mb-3 align-items-center">
                        <span class="badge bg-primary px-2.5 py-1.5 text-uppercase" id="modalPostCategory">Notice</span>
                        <span class="badge px-2.5 py-1.5" id="modalPostPriority">Priority</span>
                        <small class="text-muted ms-auto"><i class="bi bi-calendar-event me-1"></i><span id="modalPostDate">Date</span></small>
                    </div>
                    
                    <!-- Linked Training Card -->
                    <div class="card border border-info border-start-0 border-end-0 border-bottom-0 bg-info bg-opacity-10 mb-4 d-none" id="modalTrainingCard">
                        <div class="card-body py-3 d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="fw-bold text-info mb-1"><i class="bi bi-mortarboard-fill me-2"></i>Linked Training Program</h6>
                                <small class="text-muted">This announcement is connected with a scheduled training course.</small>
                            </div>
                            <a href="/Dashboard/Staff/Training" class="btn btn-info btn-sm text-white fw-bold"><i class="bi bi-arrow-right me-1"></i>Access Trainings</a>
                        </div>
                    </div>

                    <div class="text-dark leading-relaxed" style="font-size: 1.05rem; white-space: pre-line;" id="modalPostContent">
                        Post Content Body
                    </div>
                </div>
                <div class="modal-footer border-light">
                    <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }

        // View Post Modal populating
        document.querySelectorAll('.btn-view-post').forEach(button => {
            button.addEventListener('click', function() {
                const title = this.getAttribute('data-title');
                const category = this.getAttribute('data-category');
                const priority = this.getAttribute('data-priority');
                const content = this.getAttribute('data-content');
                const date = this.getAttribute('data-date');
                const trainingid = this.getAttribute('data-trainingid');

                document.getElementById('modalPostTitle').innerText = title;
                document.getElementById('modalPostCategory').innerText = category;
                document.getElementById('modalPostContent').innerText = content;
                document.getElementById('modalPostDate').innerText = date;

                // Priority badge colors
                const priorityBadge = document.getElementById('modalPostPriority');
                priorityBadge.innerText = priority;
                priorityBadge.className = 'badge px-2.5 py-1.5 ';
                if (priority === 'High') {
                    priorityBadge.classList.add('bg-danger', 'text-white');
                } else if (priority === 'Medium') {
                    priorityBadge.classList.add('bg-warning', 'text-dark');
                } else {
                    priorityBadge.classList.add('bg-info', 'text-dark');
                }

                // Linked training card
                const trainingCard = document.getElementById('modalTrainingCard');
                if (trainingid && trainingid !== '') {
                    trainingCard.classList.remove('d-none');
                } else {
                    trainingCard.classList.add('d-none');
                }

                const viewModal = new bootstrap.Modal(document.getElementById('viewPostModal'));
                viewModal.show();
            });
        });
    </script>
</body>
</html>
