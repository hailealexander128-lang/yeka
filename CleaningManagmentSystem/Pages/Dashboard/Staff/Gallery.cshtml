@page
@{
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole");
    
    if (userName == null)
    {
        Response.Redirect("/Login");
        return;
    }
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
}

<div class="main-content p-4">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2"><i class="bi bi-images me-2"></i>Photo Gallery</h1>
        <button class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-2"></i>Upload Photo</button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-images display-4 text-primary"></i>
                    <h4 class="mt-2">85</h4>
                    <p class="text-muted mb-0">Total Photos</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-folder display-4 text-success"></i>
                    <h4 class="mt-2">12</h4>
                    <p class="text-muted mb-0">Albums</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
