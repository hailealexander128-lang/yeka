@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.RegisterReceiptModel
@{
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";

    ViewData["Title"] = "Staff Dashboard - Receipt Registration";

    var isEditMode = Model.EditMode == "true";
}

<div class="main-content p-4">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="h4 mb-0">
                        <i class="bi bi-receipt me-2"></i>Staff Dashboard - Receipt Registration
                    </h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item active">Register Receipts</li>
                        </ol>
                    </nav>
                </div>

                @if (!string.IsNullOrEmpty(Model.Message))

                {
                    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show"
                        role="alert">
                        @Model.Message
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (Model.FromApproval == "true" && Model.PrefilledReceipt != null)
                {
                    dynamic pf = Model.PrefilledReceipt;
                    string pfMahberat = pf.mahberat_name?.ToString() ?? "—";
                    string pfDriver   = pf.driver_name?.ToString()   ?? "—";
                    string pfKg       = pf.kilogram?.ToString()      ?? "0";
                    string pfPrice    = pf.price?.ToString()         ?? "0";
                    <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-start gap-3">
                        <i class="bi bi-info-circle-fill fs-4 text-info flex-shrink-0 mt-1"></i>
                        <div>
                            <strong>Pre-filled from Approved Receipt #@Model.ApprovedReceiptId</strong>
                            <div class="mt-1" style="font-size:.88rem">
                                Review details below and click <strong>Register Receipt</strong> to complete billing.
                            </div>
                            <div class="d-flex gap-3 mt-2 flex-wrap" style="font-size:.82rem">
                                <span><i class="bi bi-building text-primary me-1"></i><strong>Mahberat:</strong> @pfMahberat</span>
                                <span><i class="bi bi-person text-secondary me-1"></i><strong>Driver:</strong> @pfDriver</span>
                                <span><i class="bi bi-boxes text-info me-1"></i><strong>KG:</strong> @pfKg</span>
                                <span><i class="bi bi-cash text-success me-1"></i><strong>Rate:</strong> ETB @pfPrice</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Quick Stats Cards -->
                <div class="row mb-4">
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="display-6 text-primary mb-2">
                                    <i class="bi bi-geo-alt"></i>
                                </div>
                                <h6 class="card-title">Weredas</h6>
                                <p class="h3 fw-bold text-primary">@Model.Weredas.Count</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="display-6 text-success mb-2">
                                    <i class="bi bi-building"></i>
                                </div>
                                <h6 class="card-title">Mahberats</h6>
                                <p class="h3 fw-bold text-success">@Model.Mahberats.Count</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="display-6 text-warning mb-2">
                                    <i class="bi bi-truck"></i>
                                </div>
                                <h6 class="card-title">Vehicles</h6>
                                <p class="h3 fw-bold text-warning">@Model.Vehicles.Count</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="display-6 text-info mb-2">
                                    <i class="bi bi-person-badge"></i>
                                </div>
                                <h6 class="card-title">Drivers</h6>
                                <p class="h3 fw-bold text-info">@Model.Drivers.Count</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filter Section -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-funnel me-2"></i>Filter Receipts
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="get" class="row g-3">
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-bold">Wereda</label>
                                <select class="form-select" asp-for="FilterWeredaId">
                                    <option value="">-- All Weredas --</option>
                                    @foreach (var w in Model.Weredas)

                                    {
                                        <option value="@w.Id">@w.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-bold">Mahberat</label>
                                <select class="form-select" asp-for="FilterMahberatId">
                                    <option value="">-- All Mahberats --</option>
                                    @foreach (var m in Model.Mahberats)

                                    {
                                        <option value="@m.Id">@m.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-bold">Plate Number</label>
                                <input type="text" class="form-control" asp-for="FilterPlate"
                                    placeholder="Enter plate number" />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-bold">Driver</label>
                                <select class="form-select" asp-for="FilterDriverId">
                                    <option value="">-- All Drivers --</option>
                                    @foreach (var d in Model.Drivers)

                                    {
                                        <option value="@d.Id">@d.FullName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-bold">Start Date</label>
                                <input type="date" class="form-control" asp-for="FilterStartDate" />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-bold">End Date</label>
                                <input type="date" class="form-control" asp-for="FilterEndDate" />
                            </div>

                            <div class="col-md-3 col-sm-6 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    <i class="bi bi-search me-2"></i>Filter
                                </button>
                            </div>

                            <div class="col-md-3 col-sm-6 d-flex align-items-end">
                                <a href="/Dashboard/Staff/RegisterReceipt"
                                    class="btn btn-outline-secondary btn-lg w-100">
                                    <i class="bi bi-x-circle me-2"></i>Clear
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Toolbar -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-list me-2"></i>Receipts
                        </h5>
                        <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal"
                            data-bs-target="#registerReceiptModal" id="openModalBtn">
                            <i class="bi bi-plus-circle me-2"></i>Register New Receipt
                        </button>
                    </div>
                </div>

                <!-- Recent Receipts Table -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-clock-history me-2"></i>Recent Receipts
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <form method="post" asp-page-handler="GenerateBill">
                        <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center">
                            <span class="text-muted">Select receipts to generate a bill. Status will be changed to Billed.</span>
                            <button type="submit" class="btn btn-dark" onclick="return confirm('Generate bill for selected receipts?');">
                                <i class="bi bi-file-earmark-pdf me-2"></i>Generate Bill
                            </button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;">
                                            <input class="form-check-input" type="checkbox" id="selectAll">
                                        </th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Wereda</th>
                                        <th>Mahberat</th>
                                        <th>Plate</th>
                                        <th>Driver</th>
                                        <th>Kilogram</th>
                                        <th>Price in ETB</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.RecentReceipts != null && Model.RecentReceipts.Any())

                                    {

                                        foreach (var r in Model.RecentReceipts)

                                        {
                                            <tr>
                                                <td>
                                                    @if (r.status == "Registered" || r.status == "Approved")
                                                    {
                                                        <input class="form-check-input receipt-checkbox" type="checkbox" name="selectedReceipts" value="@r.id">
                                                    }
                                                </td>
                                                <td>@(((DateTime)r.receipt_date).ToString("yyyy-MM-dd"))</td>
                                                <td>@(((TimeSpan)r.receipt_time).ToString(@"hh\:mm"))</td>
                                                <td>@r.wereda_name</td>
                                                <td>@r.mahberat_name</td>
                                                <td><strong>@r.plate_number</strong></td>
                                                <td>@r.driver_name</td>
                                                <td><span class="badge bg-primary">@((decimal)r.kilogram) kg</span></td>
                                                <td><span class="badge bg-success">@(((decimal)r.total_price).ToString("N2"))
                                                        ETB</span></td>
                                                <td>
                                                    @if (r.status == "Approved")
                                                    {
                                                        <span class="badge bg-success bg-opacity-10 text-success border border-success">Approved</span>
                                                    }
                                                    else if (r.status == "Pending")
                                                    {
                                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">Pending</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary">@r.status</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (r.status == "Registered" || r.status == "Pending")
                                                    {
                                                        <a href="/Dashboard/Staff/RegisterReceipt?editId=@r.id"
                                                            class="btn btn-sm btn-warning me-1 mb-1" title="Edit">
                                                            <i class="bi bi-pencil"></i> 
                                                        </a>
                                                        <button type="submit" asp-page-handler="Delete" name="id" value="@r.id"
                                                                class="btn btn-sm btn-danger mb-1 me-1" title="Delete"
                                                                onclick="return confirm('Are you sure you want to delete this receipt?');">
                                                            <i class="bi bi-trash"></i> 
                                                        </button>
                                                    }
                                                    
                                                    @if (r.status == "Registered" || r.status == "Approved")
                                                    {
                                                        <button type="submit" asp-page-handler="GenerateBill" name="selectedReceipts" value="@r.id"
                                                                class="btn btn-sm btn-info me-1 mb-1 text-white" title="Generate Bill"
                                                                onclick="return confirm('Generate bill for this receipt?');">
                                                            <i class="bi bi-file-earmark-pdf"></i> Bill
                                                        </button>
                                                    }
                                                    
                                                    @if (r.status == "Billed")
                                                    {
                                                        <span 
                                                                class="btn btn-sm btn-success me-1 mb-1" title="Mark as Paid"
                                                                >
                                                            <i class="bi bi-cash"></i> Paid
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }

                                    }

                                    else

                                    {
                                        <tr>
                                            <td colspan="10" class="text-center text-muted py-4">
                                                No receipts found
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.receipt-checkbox');
        
        if (selectAll) {
            selectAll.addEventListener('change', function() {
                checkboxes.forEach(cb => {
                    cb.checked = selectAll.checked;
                });
            });
        }
    });
</script>
<!-- Register/Edit Receipt Modal -->
<div class="modal fade" id="registerReceiptModal" tabindex="-1" aria-labelledby="registerReceiptModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="registerReceiptModalLabel">
                    <i class="bi bi-clipboard-plus me-2"></i>
                    @(isEditMode ? "Edit Receipt" : "Register New Receipt")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" id="receiptForm">
                    @if (isEditMode)

                    {
                        <input type="hidden" asp-for="EditId" />
                        <input type="hidden" asp-for="EditMode" />
                    }

                    <div class="row g-3">
                        <!-- Wereda -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Choose Your Wereda</label>
                            <select class="form-select form-select-lg" asp-for="WeredaId" required>
                                <option value="">-- Select Wereda --</option>
                                @foreach (var w in Model.Weredas)

                                {
                                    <option value="@w.Id">@w.Name</option>
                                }
                            </select>
                            <span asp-validation-for="WeredaId" class="text-danger"></span>
                        </div>

                        <!-- Mahaber -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Choose Your Mahaber</label>
                            <select class="form-select form-select-lg" asp-for="MahberatId" required>
                                <option value="">-- Select Mahaber --</option>
                                @foreach (var m in Model.Mahberats)

                                {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            </select>
                            <span asp-validation-for="MahberatId" class="text-danger"></span>
                        </div>

                        <!-- Plate Number -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Choose Your Plate Number</label>
                            <select class="form-select form-select-lg" asp-for="VehicleId" required>
                                <option value="">-- Select Plate Number --</option>
                                @foreach (var v in Model.Vehicles)

                                {
                                    <option value="@v.Id">@v.PlateNumber</option>
                                }
                            </select>
                            <span asp-validation-for="VehicleId" class="text-danger"></span>
                        </div>

                        <!-- Driver -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Choose Your Driver</label>
                            <select class="form-select form-select-lg" asp-for="DriverId" required>
                                <option value="">-- Select Driver --</option>
                                @foreach (var d in Model.Drivers)

                                {
                                    <option value="@d.Id">@d.FullName</option>
                                }
                            </select>
                            <span asp-validation-for="DriverId" class="text-danger"></span>
                        </div>

                        <!-- Time -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Enter Your Time</label>
                            <input type="time" class="form-control form-control-lg" asp-for="TimeString" required />
                            <span asp-validation-for="TimeString" class="text-danger"></span>
                        </div>

                        <!-- Date -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Enter Your Date</label>
                            <input type="date" class="form-control form-control-lg" asp-for="Date" required />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>

                        <!-- Kilogram -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Kilogram</label>
                            <div class="input-group input-group-lg">
                                <input type="number" class="form-control form-control-lg" asp-for="Kilogram"
                                    id="kgInput"
                                    placeholder="Enter Kilogram" step="0.01" min="0.01" required
                                    value="@(Model.Kilogram > 0 ? Model.Kilogram.ToString() : (Model.DefaultKg > 0 ? Model.DefaultKg.ToString() : ""))" />
                                <span class="input-group-text">kg</span>
                            </div>
                            <span asp-validation-for="Kilogram" class="text-danger"></span>
                        </div>

                        <!-- Price per kg -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                Price per kg (ETB)
                                @if (Model.DefaultPricePerKg > 0)
                                {
                                    <small class="text-muted ms-1">(default: @Model.DefaultPricePerKg)</small>
                                }
                            </label>
                            <div class="input-group input-group-lg">
                                <input type="number" class="form-control form-control-lg" asp-for="Price"
                                    id="priceInput"
                                    placeholder="Enter price per kg" step="0.01" min="0.01" required
                                    value="@(Model.Price > 0 ? Model.Price.ToString() : (Model.DefaultPricePerKg > 0 ? Model.DefaultPricePerKg.ToString() : ""))" />
                                <span class="input-group-text">ETB/kg</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <!-- Live Total -->
                        <div class="col-12">
                            <div class="alert alert-success py-2 px-3 d-flex align-items-center justify-content-between mb-0">
                                <span class="fw-bold"><i class="bi bi-calculator me-2"></i>Calculated Total</span>
                                <span class="fs-5 fw-bold" id="totalDisplay">— ETB</span>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                @if (isEditMode)

                {
                    <a href="/Dashboard/Staff/RegisterReceipt" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                    <button type="submit" form="receiptForm" asp-page-handler="Update" class="btn btn-warning">
                        <i class="bi bi-pencil-square me-2"></i>Update Receipt
                    </button>
                }

                else

                {
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-2"></i>Close
                    </button>
                    <button type="submit" form="receiptForm" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Register Receipt
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .form-select:focus,
        .form-control:focus {
            border-color: #008080;
            box-shadow: 0 0 0 0.25rem rgba(0, 128, 128, 0.25);
        }

        .btn-primary {
            background-color: #008080;
            border-color: #008080;
        }

        .btn-primary:hover {
            background-color: #006666;
            border-color: #006666;
        }

        td form {
            display: inline;
        }
    </style>
}

@section Scripts {
    <script>
        // ── Live total calculation ──────────────────────────────────
        function calcTotal() {
            var kg    = parseFloat(document.getElementById('kgInput')?.value)    || 0;
            var price = parseFloat(document.getElementById('priceInput')?.value) || 0;
            var total = kg * price;
            var el = document.getElementById('totalDisplay');
            if (el) {
                el.textContent = total > 0
                    ? total.toLocaleString('en-ET', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ETB'
                    : '— ETB';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            var kgEl    = document.getElementById('kgInput');
            var priceEl = document.getElementById('priceInput');
            if (kgEl)    kgEl.addEventListener('input', calcTotal);
            if (priceEl) priceEl.addEventListener('input', calcTotal);
            calcTotal(); // run on load for pre-filled values

            @if (isEditMode)
            {
                <text>
                    var editModal = new bootstrap.Modal(document.getElementById('registerReceiptModal'));
                    editModal.show();
                </text>
            }
        });
    </script>
}