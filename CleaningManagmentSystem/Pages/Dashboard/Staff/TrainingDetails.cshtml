@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.TrainingDetailsModel
@{
    var userName = HttpContext.Session.GetString("UserName");
    if (userName == null) { Response.Redirect("/Login"); return; }
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
}

<div class="main-content p-4">
    <div class="mb-4">
        <a href="/Dashboard/Staff/Training" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to Schedule
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-award-fill fs-3 me-3 text-success"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-0">Course Complete!</h5>
                    <p class="mb-0">@Model.SuccessMessage</p>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Main Content Area -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                        <div>
                            @{
                                var categoryBadge = Model.Training.Category switch
                                {
                                    "Safety" => "bg-danger bg-opacity-10 text-danger border border-danger-subtle",
                                    "Equipment" => "bg-success bg-opacity-10 text-success border border-success-subtle",
                                    "Customer Service" => "bg-info bg-opacity-10 text-info border border-info-subtle",
                                    "Operations" => "bg-warning bg-opacity-10 text-warning border border-warning-subtle",
                                    "Leadership" => "bg-primary bg-opacity-10 text-primary border border-primary-subtle",
                                    _ => "bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle"
                                };
                            }
                            <span class="badge @categoryBadge px-2.5 py-1.5 text-uppercase mb-2">@Model.Training.Category</span>
                            <h2 class="fw-bold text-dark mb-1">@Model.Training.Title</h2>
                        </div>
                        
                        <div>
                            @{
                                var statusClass = Model.Training.Status switch
                                {
                                    "Completed" => "bg-success text-white",
                                    "In Progress" => "bg-primary text-white",
                                    "Upcoming" => "bg-warning text-dark",
                                    _ => "bg-secondary text-white"
                                };
                            }
                            <span class="badge @statusClass px-3 py-2 fs-6">@Model.Training.Status</span>
                        </div>
                    </div>

                    <!-- Progress Stepper -->
                    <div class="p-3 bg-light rounded-3 mb-4 d-flex justify-content-between text-center align-items-center">
                        <div class="flex-fill">
                            <div class="rounded-circle bg-success text-white d-inline-flex justify-content-center align-items-center mb-1" style="width: 32px; height: 32px;">1</div>
                            <div class="small fw-semibold">Scheduled</div>
                        </div>
                        <div class="flex-fill border-top border-2 border-success" style="min-width: 50px;"></div>
                        <div class="flex-fill">
                            <div class="rounded-circle @(Model.Training.Status == "In Progress" || Model.Training.Status == "Completed" ? "bg-success text-white" : "bg-secondary text-white-50") d-inline-flex justify-content-center align-items-center mb-1" style="width: 32px; height: 32px;">2</div>
                            <div class="small fw-semibold">In Progress</div>
                        </div>
                        <div class="flex-fill border-top border-2 @(Model.Training.Status == "Completed" ? "border-success" : "border-secondary")" style="min-width: 50px;"></div>
                        <div class="flex-fill">
                            <div class="rounded-circle @(Model.Training.Status == "Completed" ? "bg-success text-white" : "bg-secondary text-white-50") d-inline-flex justify-content-center align-items-center mb-1" style="width: 32px; height: 32px;">
                                @if (Model.Training.Status == "Completed") { <i class="bi bi-check-lg"></i> } else { <span>3</span> }
                            </div>
                            <div class="small fw-semibold">Completed</div>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark mb-2">Program Overview</h5>
                    <p class="text-muted leading-relaxed mb-4">
                        @if (!string.IsNullOrEmpty(Model.Training.Description))
                        {
                            @Model.Training.Description
                        }
                        else
                        {
                            <span>No formal description is available for this training program. Please review the course materials provided below and consult your supervisor or designated trainer if you have any operational queries.</span>
                        }
                    </p>

                    <!-- Dynamic Course Materials Section -->
                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-folder-symlink me-2 text-primary"></i>Required Course Materials</h5>
                    <div class="row g-3">
                        @if (string.IsNullOrEmpty(Model.Training.Materials) || Model.Training.Materials.Contains("PDF"))
                        {
                            <div class="col-md-6">
                                <div class="card h-100 border border-light-subtle shadow-sm hover-up">
                                    <div class="card-body d-flex align-items-center p-3">
                                        <div class="bg-danger bg-opacity-10 text-danger p-3 rounded me-3">
                                            <i class="bi bi-file-earmark-pdf fs-2"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Training Manual.pdf</h6>
                                            <small class="text-muted">Standard Operating Procedure</small>
                                            <div class="mt-1"><a href="#" onclick="alert('Downloading training PDF document...')" class="small text-decoration-none fw-semibold">Download Material</a></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (string.IsNullOrEmpty(Model.Training.Materials) || Model.Training.Materials.Contains("Video"))
                        {
                            <div class="col-md-6">
                                <div class="card h-100 border border-light-subtle shadow-sm hover-up">
                                    <div class="card-body d-flex align-items-center p-3">
                                        <div class="bg-warning bg-opacity-10 text-warning p-3 rounded me-3">
                                            <i class="bi bi-play-circle fs-2"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Instructional Video</h6>
                                            <small class="text-muted">Interactive Video Lecture</small>
                                            <div class="mt-1"><a href="#" onclick="alert('Launching course video player...')" class="small text-decoration-none fw-semibold text-warning">Watch Online</a></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (string.IsNullOrEmpty(Model.Training.Materials) || Model.Training.Materials.Contains("Exam"))
                        {
                            <div class="col-md-6">
                                <div class="card h-100 border border-light-subtle shadow-sm hover-up">
                                    <div class="card-body d-flex align-items-center p-3">
                                        <div class="bg-info bg-opacity-10 text-info p-3 rounded me-3">
                                            <i class="bi bi-card-checklist fs-2"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Assessment Quiz</h6>
                                            <small class="text-muted">Required Competency Test</small>
                                            <div class="mt-1"><a href="#" onclick="alert('Opening validation exam portal...')" class="small text-decoration-none fw-semibold text-info">Begin Assessment</a></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Complete Training Card -->
            @if (Model.Training.Status != "Completed")
            {
                <div class="card border-0 shadow-sm bg-gradient text-white" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-patch-check display-4 mb-2"></i>
                        <h4 class="fw-bold">Ready to complete the training?</h4>
                        <p class="mb-4">Once you have successfully reviewed the manuals, watched the instructional videos, or passed the necessary exam milestones, click the button below to certify completion.</p>
                        <form method="post" asp-page-handler="Complete" asp-route-id="@Model.Training.Id">
                            <button type="submit" class="btn btn-light btn-lg px-5 fw-bold text-success shadow"><i class="bi bi-check-circle-fill me-2 text-success"></i>Mark Training as Completed</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm bg-light text-center">
                    <div class="card-body p-5">
                        <i class="bi bi-check-circle-fill display-3 text-success mb-3"></i>
                        <h3 class="fw-bold text-success">Certification Complete!</h3>
                        <p class="text-muted max-w-lg mx-auto">This training program was verified and completed. Your supervisor has been notified of your active participation and certification. Keep up the excellent work!</p>
                        <div class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 mt-2">
                            <i class="bi bi-clock me-1"></i> Status: Certified Completed
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar Meta Box -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-info-circle-fill me-2 text-primary"></i>Session Details</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3 d-flex align-items-center">
                        <div class="bg-light p-2 rounded.5 text-muted me-3">
                            <i class="bi bi-person-badge fs-4"></i>
                        </div>
                        <div>
                            <div class="small text-muted">Trainer Name</div>
                            <div class="fw-bold text-dark">@Model.Training.Trainer</div>
                        </div>
                    </div>
                    <div class="mb-3 d-flex align-items-center">
                        <div class="bg-light p-2 rounded.5 text-muted me-3">
                            <i class="bi bi-geo-alt fs-4"></i>
                        </div>
                        <div>
                            <div class="small text-muted">Training Venue</div>
                            <div class="fw-bold text-dark">@Model.Training.Location</div>
                        </div>
                    </div>
                    <div class="mb-3 d-flex align-items-center">
                        <div class="bg-light p-2 rounded.5 text-muted me-3">
                            <i class="bi bi-calendar-range fs-4"></i>
                        </div>
                        <div>
                            <div class="small text-muted">Duration Period</div>
                            <div class="fw-bold text-dark">@Model.Training.StartDate.ToString("MMM dd") - @Model.Training.EndDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                    <hr>
                    <div class="d-flex align-items-center">
                        <div class="bg-light p-2 rounded.5 text-muted me-3">
                            <i class="bi bi-person-check fs-4"></i>
                        </div>
                        <div>
                            <div class="small text-muted">Assigned Person</div>
                            <div class="fw-bold text-primary">
                                @if (Model.Training.AssignedToUserId.HasValue)
                                {
                                    @Model.Training.AssignedToUserName
                                }
                                else
                                {
                                    <span>All Staff (General)</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Helpful notice -->
            <div class="card border-0 shadow-sm text-dark bg-white" style="border-left: 4px solid #3b82f6 !important;">
                <div class="card-body">
                    <h6 class="fw-bold mb-1"><i class="bi bi-lightbulb text-warning me-1"></i> Need Assistance?</h6>
                    <small class="text-muted leading-snug d-block">If you experience trouble accessing course materials, links, or if you believe this training category was assigned in error, please report to the Operation Desk immediately.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-up {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-up:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important;
    }
</style>
