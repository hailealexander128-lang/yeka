@page
@{
    var userName = HttpContext.Session.GetString("UserName");

    if (userName == null)
    {
        Response.Redirect("/Login");
        return;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Dispatch - Dispatch Officer - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/DispatchOfficer"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/DispatchOfficer"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>

    <nav id="sidebarMenu" class="sidebar d-lg-none">
        @await Html.PartialAsync("~/Pages/Dashboard/DispatchOfficer/_Sidebar.cshtml")
    </nav>
    <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
        @await Html.PartialAsync("~/Pages/Dashboard/DispatchOfficer/_Sidebar.cshtml")
    </nav>

    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2">Create Dispatch</h1>
            <span class="badge bg-info">Dispatch Officer</span>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-send display-4 text-primary"></i>
                        <h3 class="mt-2">28</h3>
                        <p>Active Dispatches</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-check2-all display-4 text-success"></i>
                        <h3 class="mt-2">156</h3>
                        <p>Completed Today</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-clock display-4 text-warning"></i>
                        <h3 class="mt-2">5</h3>
                        <p>Pending</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h4>Recent Dispatches</h4>
            <table class="table table-striped">
                <thead>
                    <tr><th>Dispatch ID</th><th>Task</th><th>Assigned To</th><th>Wereda</th><th>Time</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr><td>DSP-001</td><td>Cleaning Service</td><td>Team A</td><td>Wereda 01</td><td>08:00 AM</td><td><span class="badge bg-success">In Progress</span></td></tr>
                    <tr><td>DSP-002</td><td>Equipment Delivery</td><td>Team B</td><td>Wereda 02</td><td>09:30 AM</td><td><span class="badge bg-primary">Assigned</span></td></tr>
                    <tr><td>DSP-003</td><td>Supply Restock</td><td>Team C</td><td>Wereda 03</td><td>10:00 AM</td><td><span class="badge bg-warning">Pending</span></td></tr>
                    <tr><td>DSP-004</td><td>Maintenance Check</td><td>Team A</td><td>Wereda 01</td><td>11:00 AM</td><td><span class="badge bg-success">Completed</span></td></tr>
                    <tr><td>DSP-005</td><td>Special Cleaning</td><td>Team D</td><td>Wereda 04</td><td>01:00 PM</td><td><span class="badge bg-primary">Assigned</span></td></tr>
                </tbody>
            </table>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.innerWidth < 992) toggleSidebar();
            });
        });
    </script>
</body>
</html>