@{
    var currentPath = Context.Request.Path.Value ?? "";
    
    bool IsActive(string path, bool exact = false)
    {
        if (exact)
        {
            return currentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
        }
        return currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }
}
<div class="sidebar-scroll pt-3" style="height: 100%;">
    <div class="pb-3 mb-3 border-bottom text-center">
        <h5 class="text-white fw-bold"><i class="bi bi-droplet-fill text-info me-1"></i>Yeka Cleaning</h5>
        <small class="text-white-50">Dispatch Officer</small>
    </div>
    <ul class="nav flex-column">
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/DispatchOfficer", true) ? "active" : "")" href="/Dashboard/DispatchOfficer">
                <i class="bi bi-house me-2"></i>Home
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/DispatchOfficer/MeetingRoom") ? "active" : "")" href="/Dashboard/DispatchOfficer/MeetingRoom">
                <i class="bi bi-calendar-event me-2"></i>Meeting Room
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/DispatchOfficer/AllMahberatReport") ? "active" : "")" href="/Dashboard/DispatchOfficer/AllMahberatReport">
                <i class="bi bi-file-earmark-text me-2"></i>All Mahberat Report
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/DispatchOfficer/CreateDispatch") ? "active" : "")" href="/Dashboard/DispatchOfficer/CreateDispatch">
                <i class="bi bi-send me-2"></i>Create Dispatch
