            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/DispatchOfficer/Contact") ? "active" : "")" href="/Dashboard/DispatchOfficer/Contact">
                <i class="bi bi-envelope me-2"></i>Contact
            </a>
        </li>
        <li class="nav-item mt-4">
            <a class="nav-link text-warning fw-semibold" href="/Login?logout=1">
