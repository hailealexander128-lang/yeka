@page
@{
    var userName = HttpContext.Session.GetString("UserName");

    if (userName == null)
    {
        Response.Redirect("/Login");
        return;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>All Mahberat Report - Dispatch Officer - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

    <!-- Desktop Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Dashboard/DispatchOfficer"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
            <div class="nav-user">
                <span>Welcome, @userName</span>
                <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </nav>

    <!-- Mobile Navbar -->
    <nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" onclick="toggleSidebar()">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/Dashboard/DispatchOfficer"><i class="bi bi-droplet-fill"></i> Yeka</a>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </nav>

    <nav id="sidebarMenu" class="sidebar d-lg-none">
        @await Html.PartialAsync("~/Pages/Dashboard/DispatchOfficer/_Sidebar.cshtml")
    </nav>
    <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform: none; padding-top: 56px;">
        @await Html.PartialAsync("~/Pages/Dashboard/DispatchOfficer/_Sidebar.cshtml")
    </nav>

    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2">All Mahberat Report</h1>
            <span class="badge bg-info">Dispatch Officer</span>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-file-earmark-medical display-4 text-primary"></i>
                        <h3 class="mt-2">156</h3>
                        <p>Total Reports</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-check-circle display-4 text-success"></i>
                        <h3 class="mt-2">132</h3>
                        <p>Completed</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-hourglass-split display-4 text-warning"></i>
                        <h3 class="mt-2">24</h3>
                        <p>Pending</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h4>Mahberat Reports</h4>
            <table class="table table-striped">
                <thead>
                    <tr><th>Report ID</th><th>Mahber Type</th><th>Wereda</th><th>Date Submitted</th><th>Submitted By</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr><td>MBR-001</td><td>Cleaning Request</td><td>Wereda 01</td><td>2026-04-15</td><td>John Doe</td><td><span class="badge bg-success">Completed</span></td></tr>
                    <tr><td>MBR-002</td><td>Equipment Request</td><td>Wereda 02</td><td>2026-04-16</td><td>Jane Smith</td><td><span class="badge bg-success">Completed</span></td></tr>
                    <tr><td>MBR-003</td><td>Staff Assignment</td><td>Wereda 03</td><td>2026-04-17</td><td>Mike Johnson</td><td><span class="badge bg-warning">Pending</span></td></tr>
                    <tr><td>MBR-004</td><td>Supply Request</td><td>Wereda 01</td><td>2026-04-18</td><td>Sarah Williams</td><td><span class="badge bg-primary">In Progress</span></td></tr>
                    <tr><td>MBR-005</td><td>Maintenance</td><td>Wereda 04</td><td>2026-04-19</td><td>Tom Brown</td><td><span class="badge bg-warning">Pending</span></td></tr>
                </tbody>
            </table>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.innerWidth < 992) toggleSidebar();
            });
        });
    </script>
</body>
</html>